{
  "name": "@stricahq/cardano-codec",
  "version": "2.0.4",
  "description": "Cardano Codec library for parsing Cardano CBOR data types",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "unpkg": "./dist/index.min.js",
  "jsdelivr": "./dist/index.min.js",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cardano",
    "strica",
    "cardano cbor parser",
    "cardano cbor decoder"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/StricaHQ/cardano-codec.git"
  },
  "bugs": {
    "url": "https://github.com/StricaHQ/cardano-codec/issues"
  },
  "homepage": "https://github.com/StricaHQ/cardano-codec#readme",
  "scripts": {
    "docs": "rm -rf docs && typedoc",
    "build": "rm -rf dist && tsup && cp shims/index.mjs shims/index.d.mts dist/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "prepack": "yarn build",
    "prepublishOnly": "yarn build && yarn test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Strica",
  "license": "Apache-2.0",
  "dependencies": {
    "@stricahq/cbors": "^1.1.0",
    "bignumber.js": "^9.1.2",
    "blakejs": "^1.2.1",
    "buffer": "^6.0.3",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/lodash": "^4.17.5",
    "@types/node": "^20.14.2",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^17.7.0",
    "prettier": "^3.3.2",
    "tsup": "^8.5.0",
    "typedoc": "^0.25.13",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "packageManager": "yarn@4.17.1"
}
